@article{buschPRODIGEEnvelopeDisk2026,
  title = {{{PRODIGE}} - {{Envelope}} to Disk with {{NOEMA}}: {{VII}}. ({{Complex}}) Organic Molecules in the {{NGC1333 IRAS 4B1}} Outflow: {{A}} New Laboratory for Shock Chemistry},
